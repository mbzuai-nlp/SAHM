# Copy to .env and fill in. Then:  set -a; source .env; set +a
# NEVER commit .env (it is git-ignored).

# Hugging Face token with READ access to the SahmBenchmark datasets/models.
HF_TOKEN=

# Judge / API-model key (OpenAI by default). Swap for your provider's key.
OPENAI_API_KEY=

# Optional extra providers (only if you use them in models.yaml):
# DEEPINFRA_API_KEY=
# GEMINI_API_KEY=
